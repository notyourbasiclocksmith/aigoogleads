# Database
DATABASE_URL=postgresql+asyncpg://ignite:ignite@localhost:5432/ignite_ads
DATABASE_URL_SYNC=postgresql://ignite:ignite@localhost:5432/ignite_ads

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET=change-me-to-a-random-secret-key
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=60
JWT_REFRESH_EXPIRY_DAYS=30

# Encryption (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
ENCRYPTION_KEY=change-me-generate-fernet-key

# Google Ads
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REDIRECT_URI=http://localhost:3000/api/auth/google-ads/callback

# AI Image Generator (SEOpix Flask API)
IMAGE_GENERATOR_API_URL=https://ai-image-generator-kv3k.onrender.com
IMAGE_GENERATOR_API_KEY=

# S3-compatible storage
S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=ignite-ads-assets
S3_REGION=us-east-1

# App
APP_ENV=development
APP_URL=http://localhost:3000
API_URL=http://localhost:8000
CORS_ORIGINS=http://localhost:3000

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
